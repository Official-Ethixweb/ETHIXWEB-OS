PORT=4000
MONGODB_URI=mongodb://localhost:27017/teamflow
JWT_SECRET=change_me_to_a_long_random_string
CLIENT_ORIGIN=http://localhost:8080
NODE_ENV=development
RESEND_API_KEY=
EMAIL_FROM=ETHIXWEB OS <onboarding@resend.dev>

# Account lockout after repeated failed logins
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# AES-256-GCM key for encrypting bank details / 2FA secrets at rest.
# 64-char hex string (32 bytes) recommended, e.g: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=change_me_to_a_64_char_hex_string
